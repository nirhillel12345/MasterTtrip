// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ListingType {
  LOOKING_FOR
  HAS_APARTMENT
}

model User {
  id                    String          @id @default(cuid())
  email                 String          @unique
  name                  String?
  image                 String?
  bio                   String?         @db.Text
  instagram             String?
  phone                 String?
  isPremium             Boolean         @default(false)
  listings              Listing[]
  transports            Transport[]     @relation("TransportCreator")
  transportJoins        TransportJoin[]
  notificationsReceived Notification[]  @relation("NotificationRecipient")
  notificationsCreated  Notification[]  @relation("NotificationActor")
}

model Listing {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  title           String
  description     String
  location        String
  type            ListingType
  price           Float
  startDate       DateTime
  endDate         DateTime
  whatsappNumber  String
  roommatesNeeded Int
  images          String[]    @default([])
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transport {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  creatorId      String
  creator        User            @relation("TransportCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  origin         String
  destination    String
  date           DateTime
  totalSeats     Int
  availableSeats Int
  pricePerPerson Float
  description    String          @db.Text
  joins          TransportJoin[]
  notifications  Notification[]
}

model TransportJoin {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  transportId String
  userId      String
  transport   Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([transportId, userId])
}

model Notification {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  recipientId String
  actorId     String?
  transportId String?
  type        String
  title       String
  message     String     @db.Text
  readAt      DateTime?
  metadata    Json?
  recipient   User       @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User?      @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  transport   Transport? @relation(fields: [transportId], references: [id], onDelete: SetNull)
}
